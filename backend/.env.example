# Veritabanı
DATABASE_URL="postgresql://ikys_user:ikys_pass@localhost:5432/ikys_db?schema=public"

# Uygulama
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=degistir-bu-uzun-ve-rastgele-bir-string-olmali-min-64-karakter
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=degistir-baska-uzun-bir-string-min-64-karakter
JWT_REFRESH_EXPIRES_IN=7d

# 2FA
TWO_FA_APP_NAME=IKYS

# E-posta bildirimleri — Resend (önerilen, kurulum gerektirmez)
# https://resend.com → API Keys → "Create API Key". RESEND_API_KEY doluysa
# SMTP_* alanlarına hiç bakılmaz, Resend kullanılır.
RESEND_API_KEY=
RESEND_FROM=IKYS <onboarding@resend.dev>

# E-posta bildirimleri — SMTP / Gmail (RESEND_API_KEY boşsa devreye girer)
# Gmail hesabında 2FA açık olmalı; "Uygulama Şifreleri" üreterek SMTP_PASS'e yapıştır.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=kullanici@gmail.com
SMTP_PASS=uygulama_sifresi
SMTP_FROM=IKYS <kullanici@gmail.com>

# KVKK
DATA_RETENTION_DAYS=2555
AUDIT_LOG_ENABLED=true

# Bordro hesaplama parametreleri (TR 2025)
SGK_EMPLOYEE_RATE=0.14
UNEMPLOYMENT_INS_RATE=0.01
INCOME_TAX_RATE=0.15
STAMP_TAX_RATE=0.00759
